---
import { Image } from 'astro:assets';
import logo from "../assets/icon.png";

---

<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-brand">
      <Image src={logo} alt="" width={32} height={32} class="nav-logo" loading="eager" />
      <span class="nav-title">whirling</span>
    </a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/qna">Q&A</a></li>
      <li><a href="/bpp">B++ docs</a></li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    background-color: var(--color-primary-navbar);
    background-image: linear-gradient(to bottom, var(--color-primary-navbar), var(--color-primary-navbar-bottom));
    outline: 1px solid var(--color-primary-half-transparent);
    height: var(--nav-height);
    width: 100%;
    display: flex;
    align-items: center;
    position: fixed;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(6px);
  }

  .nav-container {
    width: 100%;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .nav-title {
    font-family: "Atkinson Hyperlegible Mono", monospace;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary-bright);
  }

  .nav-logo {
    display: block;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-primary-bright);
  }

  .nav-extra {
    display: flex;
    align-items: center;
  }

  @media (max-width: 480px) {
    .nav-brand>span {
      display: none;
    }
  }
</style>
